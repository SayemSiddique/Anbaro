# Local-only service values. Replace before any non-local deployment; never commit .env.
NODE_ENV=development
HOST=0.0.0.0
PORT=3001
# Runtime database role: RLS is enforced for this non-superuser role.
DATABASE_URL=postgresql://stock_app:stock_app@localhost:5432/stock_management
# Local migration/seed role only; never use this URL in the running API.
DATABASE_ADMIN_URL=postgresql://stock_dev:stock_dev@localhost:5432/stock_management
REDIS_URL=redis://localhost:6379

# Required outside local development: use 32+ random characters and never commit it.
JWT_ACCESS_SECRET=replace-with-a-unique-local-development-secret-at-least-32-chars
WEB_ORIGIN=http://localhost:3000
# Optional comma-separated allow-list. Use this for multiple browser clients,
# such as the Expo web development server alongside the Next.js app.
WEB_ORIGINS=http://localhost:3000,http://localhost:8081,http://127.0.0.1:8081
# Behind a load balancer set to "true", a hop count, or the proxy addresses so
# request.ip (and rate-limit keys) come from X-Forwarded-For. Keep unset locally.
# TRUST_PROXY=true
# How often any API instance re-checks the durable notification outbox (ms).
# NOTIFICATION_SWEEP_INTERVAL_MS=30000
# Stripe server secrets only. Hosted Checkout/Portal keeps card data out of
# the clients and API. Webhook reconciliation refuses unsigned payloads.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_SUBSCRIPTION_PRICE_ID=
STRIPE_LOCATION_ADDON_PRICE_ID=
