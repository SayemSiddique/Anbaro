# Local-only service values. Replace before any non-local deployment; never commit .env.
NODE_ENV=development
HOST=0.0.0.0
PORT=3001
# Runtime database role: RLS is enforced for this non-superuser role.
DATABASE_URL=postgresql://stock_app:stock_app@localhost:5432/stock_management
# Local migration/seed role only; never use this URL in the running API.
DATABASE_ADMIN_URL=postgresql://stock_dev:stock_dev@localhost:5432/stock_management
REDIS_URL=redis://localhost:6379

# Required outside local development: use 32+ random characters and never commit it.
JWT_ACCESS_SECRET=replace-with-a-unique-local-development-secret-at-least-32-chars
WEB_ORIGIN=http://localhost:3000
# Optional comma-separated allow-list. Use this for multiple browser clients,
# such as the Expo web development server alongside the Next.js app.
WEB_ORIGINS=http://localhost:3000,http://localhost:8081,http://127.0.0.1:8081
# Behind a load balancer set to "true", a hop count, or the proxy addresses so
# request.ip (and rate-limit keys) come from X-Forwarded-For. Keep unset locally.
# TRUST_PROXY=true
# How often any API instance re-checks the durable notification outbox (ms).
# NOTIFICATION_SWEEP_INTERVAL_MS=30000
# Transactional email (Postmark). Unset locally: invitation, password-reset, and
# verification emails are logged and skipped so the flows stay exercisable. Set
# the server token in production to start real delivery — no code change needed.
# POSTMARK_SERVER_TOKEN=
# From address for transactional email; must be a verified Postmark sender.
# EMAIL_FROM=Anbaro <no-reply@anbaro.app>
# Error tracking (Sentry). Unset locally: capture is dormant. Set the DSN in
# production to report unhandled 5xx with request id, route, user, and tenant.
# SENTRY_DSN=
# Fraction of transactions traced (0 disables performance tracing).
# SENTRY_TRACES_SAMPLE_RATE=0
# AI assistant (Groq). Unset: /assistant/stock-proposals returns 503. Set the key
# to enable natural-language stock proposals. The model only proposes; writes
# still go through the normal permission-checked stock-event path.
# GROQ_API_KEY=
# GROQ_MODEL=llama-3.1-8b-instant
# Billing is dormant until BILLING_ENABLED=true. Flip it only after the Stripe
# Prices below exist and each workspace has a seeded entitlement row.
# BILLING_ENABLED=true
# Stripe server secrets only. Hosted Checkout/Portal keeps card data out of
# the clients and API. Webhook reconciliation refuses unsigned payloads.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Pro plan, one Price per interval (create in the Stripe dashboard):
#   $10/month, $24.99/quarter, $89.99/year. STRIPE_SUBSCRIPTION_PRICE_ID is the
#   legacy monthly fallback. Promo codes are created in Stripe and entered by the
#   customer at checkout (allow_promotion_codes is on) — no env needed. Locations
#   are tier-based (Free = 2, Pro = unlimited); the old per-location add-on Price
#   was retired, so STRIPE_LOCATION_ADDON_PRICE_ID is no longer used.
STRIPE_PRICE_ID_MONTHLY=
STRIPE_PRICE_ID_QUARTERLY=
STRIPE_PRICE_ID_ANNUAL=
STRIPE_SUBSCRIPTION_PRICE_ID=
