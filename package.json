{
  "name": "anbaro",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@10.14.0",
  "engines": {
    "node": ">=22 <25",
    "pnpm": ">=10"
  },
  "scripts": {
    "dev": "pnpm --parallel --filter @anbaro/web --filter @anbaro/mobile --filter @anbaro/api dev",
    "dev:web": "pnpm --filter @anbaro/web dev",
    "dev:mobile": "pnpm --filter @anbaro/mobile dev",
    "dev:api": "pnpm --filter @anbaro/api dev",
    "lint": "pnpm -r --if-present lint",
    "typecheck": "pnpm -r --if-present typecheck",
    "test": "pnpm -r --if-present test",
    "build": "pnpm --filter @anbaro/contracts build && pnpm --filter @anbaro/design-tokens build && pnpm --filter @anbaro/api build && pnpm --filter @anbaro/web build && pnpm --filter @anbaro/mobile build",
    "format:check": "prettier --check .",
    "format": "prettier --write .",
    "brand:wordmark": "node tools/generate-wordmark.mjs",
    "brand:export": "pnpm --filter @anbaro/design-tokens build && node tools/export-brand.mjs"
  },
  "devDependencies": {
    "opentype.js": "^2.0.0",
    "prettier": "^3.6.2",
    "sharp": "^0.35.3",
    "typescript": "^5.9.2"
  }
}
