# EXPO_PUBLIC_ values are bundled into the mobile app. Never put secrets here.
EXPO_PUBLIC_API_BASE_URL=http://localhost:3001/api/v1
EXPO_PUBLIC_WEB_APP_URL=http://localhost:3000
# Error tracking (Sentry). Unset locally: capture is dormant. Set the DSN (a
# public project identifier, not a secret) to report mobile errors. DSN wired in
# plan Session 8.
# EXPO_PUBLIC_SENTRY_DSN=
# Fraction of transactions traced (0 disables performance tracing).
# EXPO_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0
