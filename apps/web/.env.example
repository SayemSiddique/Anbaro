# Browser-visible values must use the NEXT_PUBLIC_ prefix and must not contain secrets.
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001/api/v1
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Error tracking (Sentry). Unset locally: capture is dormant. Set the DSN (a
# public project identifier, not a secret) to report web errors. DSN wired in
# plan Session 4.
# NEXT_PUBLIC_SENTRY_DSN=
# Fraction of transactions traced (0 disables performance tracing).
# NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0
